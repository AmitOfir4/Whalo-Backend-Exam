# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/whalo?appName=<appName>

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Service Ports
PLAYER_SERVICE_PORT=3001
SCORE_SERVICE_PORT=3002
LEADERBOARD_SERVICE_PORT=3003
LOG_SERVICE_PORT=3004

# Log Worker
BATCH_SIZE=50
BATCH_INTERVAL_MS=2000
MAX_CONCURRENT_WRITES=3
TOKEN_BUCKET_CAPACITY=10
TOKEN_BUCKET_REFILL_RATE=5

# Score pipeline — TTL (seconds) for the `applied:leaderboard:<scoreKey>` marker
# that makes the leaderboard ZINCRBY idempotent between the sync (service) and
# async (worker) paths. Must exceed the worst-case worker lag. Default: 24h.
LEADERBOARD_APPLIED_TTL_SECONDS=86400
